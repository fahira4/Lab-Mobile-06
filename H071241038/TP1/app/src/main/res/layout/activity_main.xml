<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp">

            <TextView
                android:id="@+id/tvTopUsername"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:text="🔒 aansyawalu..."
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/ivMenuAdd"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:layout_marginEnd="16dp"
                    android:src="@android:drawable/ic_menu_add"
                    app:tint="#FFFFFF" />

                <ImageView
                    android:id="@+id/ivMenuBurger"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:src="@android:drawable/ic_menu_sort_by_size"
                    app:tint="#FFFFFF" />
            </LinearLayout>
        </RelativeLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/ivProfilePic"
                android:layout_width="86dp"
                android:layout_height="86dp"
                android:scaleType="centerCrop"
                android:src="@drawable/foto_profil"
                app:shapeAppearanceOverlay="@style/CircleProfilePic"
                app:strokeColor="#262626"
                app:strokeWidth="1dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="24dp"
                android:orientation="horizontal"
                android:weightSum="3">

                <LinearLayout
                    android:id="@+id/llPostingan"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="4" android:textColor="#FFFFFF" android:textSize="18sp" android:textStyle="bold" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="postingan" android:textColor="#FFFFFF" android:textSize="13sp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/llPengikut"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="1.255" android:textColor="#FFFFFF" android:textSize="18sp" android:textStyle="bold" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="pengikut" android:textColor="#FFFFFF" android:textSize="13sp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/llMengikuti"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="1.926" android:textColor="#FFFFFF" android:textSize="18sp" android:textStyle="bold" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="mengikuti" android:textColor="#FFFFFF" android:textSize="13sp" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:id="@+id/tvName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Aan Syawaluddin"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvUsername"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="\@aansyawaluddinn"
            android:textColor="#E0E0E0"
            android:textSize="13sp"
            android:layout_marginTop="2dp"
            android:layout_marginBottom="2dp"/>

        <TextView
            android:id="@+id/tvBio"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="HalaMadridYNadaMas\nSMAN 3 Makassar\nUniversitas Hasanuddin\nSistem Informasi 22"
            android:textColor="#FFFFFF"
            android:textSize="14sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="horizontal"
            android:weightSum="10">

            <Button
                android:id="@+id/btnEditProfile"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="4.5"
                android:backgroundTint="#363636"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:text="Edit profil"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:textStyle="bold"
                app:cornerRadius="8dp" />

            <Button
                android:id="@+id/btnShareProfile"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_marginStart="8dp"
                android:layout_weight="4.5"
                android:backgroundTint="#363636"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:text="Bagikan profil"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:textStyle="bold"
                app:cornerRadius="8dp" />

            <Button
                android:id="@+id/btnAddPerson"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:backgroundTint="#363636"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:text="+"
                android:textColor="#FFFFFF"
                app:cornerRadius="8dp" />
        </LinearLayout>

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <LinearLayout android:id="@+id/hlBaru" android:orientation="vertical" android:gravity="center" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginEnd="16dp">
                    <com.google.android.material.imageview.ShapeableImageView
                        android:layout_width="64dp"
                        android:layout_height="64dp"
                        android:padding="16dp"
                        android:src="@android:drawable/ic_menu_add"
                        app:tint="#FFFFFF"
                        app:shapeAppearanceOverlay="@style/CircleProfilePic"
                        app:strokeColor="#363636"
                        app:strokeWidth="1dp" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Baru" android:textColor="#FFFFFF" android:textSize="12sp" android:layout_marginTop="4dp"/>
                </LinearLayout>

                <LinearLayout android:id="@+id/hlSpesial" android:orientation="vertical" android:gravity="center" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginEnd="16dp">
                    <com.google.android.material.imageview.ShapeableImageView
                        android:layout_width="64dp"
                        android:layout_height="64dp"
                        android:src="@drawable/sorotan_spesial" android:scaleType="centerCrop"
                        app:shapeAppearanceOverlay="@style/CircleProfilePic"
                        app:strokeColor="#363636"
                        app:strokeWidth="1dp" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Spesial" android:textColor="#FFFFFF" android:textSize="12sp" android:layout_marginTop="4dp"/>
                </LinearLayout>

                <LinearLayout android:id="@+id/hlNgoding" android:orientation="vertical" android:gravity="center" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginEnd="16dp">
                    <com.google.android.material.imageview.ShapeableImageView
                        android:layout_width="64dp"
                        android:layout_height="64dp"
                        android:src="@drawable/sorotan_ngoding" android:scaleType="centerCrop"
                        app:shapeAppearanceOverlay="@style/CircleProfilePic"
                        app:strokeColor="#363636"
                        app:strokeWidth="1dp" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="ngoding" android:textColor="#FFFFFF" android:textSize="12sp" android:layout_marginTop="4dp"/>
                </LinearLayout>

                <LinearLayout android:id="@+id/hlRun" android:orientation="vertical" android:gravity="center" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginEnd="16dp">
                    <com.google.android.material.imageview.ShapeableImageView
                        android:layout_width="64dp"
                        android:layout_height="64dp"
                        android:src="@drawable/sorotan_run" android:scaleType="centerCrop"
                        app:shapeAppearanceOverlay="@style/CircleProfilePic"
                        app:strokeColor="#363636"
                        app:strokeWidth="1dp" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Run" android:textColor="#FFFFFF" android:textSize="12sp" android:layout_marginTop="4dp"/>
                </LinearLayout>
            </LinearLayout>
        </HorizontalScrollView>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="8dp"
            android:orientation="horizontal"
            android:weightSum="4">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical">
                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:padding="14dp"
                    android:src="@android:drawable/ic_menu_gallery"
                    app:tint="#FFFFFF" />
                <View
                    android:layout_width="match_parent"
                    android:layout_height="2dp"
                    android:background="#FFFFFF" />
            </LinearLayout>

            <ImageView
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:padding="14dp"
                android:src="@android:drawable/ic_media_play"
                app:tint="#888888" />

            <ImageView
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:padding="14dp"
                android:src="@android:drawable/ic_menu_recent_history"
                app:tint="#888888" />

            <ImageView
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:padding="14dp"
                android:src="@android:drawable/ic_menu_myplaces"
                app:tint="#888888" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="130dp"
            android:orientation="horizontal"
            android:weightSum="3">
            <ImageView
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginEnd="2dp"
                android:scaleType="centerCrop"
                android:src="@drawable/sorotan_spesial" /> <ImageView
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginEnd="2dp"
            android:scaleType="centerCrop"
            android:src="@drawable/sorotan_ngoding" /> <ImageView
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:scaleType="centerCrop"
            android:src="@drawable/sorotan_run" /> </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="130dp"
            android:layout_marginTop="2dp"
            android:orientation="horizontal"
            android:weightSum="3">
            <ImageView
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginEnd="2dp"
                android:scaleType="centerCrop"
                android:src="@drawable/foto_profil" /> <View
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="2" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>