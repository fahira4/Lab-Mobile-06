<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="#000000"
    android:gravity="center_horizontal">

    <ImageView
        android:id="@+id/ivEditProfilePic"
        android:layout_width="86dp"
        android:layout_height="86dp"
        android:layout_marginTop="24dp"
        android:background="@android:drawable/ic_menu_camera"
        android:backgroundTint="#888888" />

    <TextView
        android:id="@+id/tvChangePhoto"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Edit foto atau avatar"
        android:textColor="#3BADF8"
        android:textStyle="bold"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="24dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginBottom="24dp">

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Nama" android:textColor="#888888" android:textSize="12sp"/>
        <EditText
            android:id="@+id/etName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFF"
            android:backgroundTint="#333333"
            android:layout_marginBottom="12dp"
            android:inputType="textPersonName"/>

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Nama pengguna (Username)" android:textColor="#888888" android:textSize="12sp"/>
        <EditText
            android:id="@+id/etUsername"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFF"
            android:backgroundTint="#333333"
            android:layout_marginBottom="12dp"
            android:inputType="textNoSuggestions"/>

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Bio" android:textColor="#888888" android:textSize="12sp"/>
        <EditText
            android:id="@+id/etBio"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFF"
            android:backgroundTint="#333333"
            android:lines="3"
            android:gravity="top|start"
            android:inputType="textMultiLine"/>
    </LinearLayout>

    <Button
        android:id="@+id/btnSave"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:text="Simpan Perubahan"
        android:backgroundTint="#3BADF8"
        android:textColor="#FFFFFF"
        android:textStyle="bold"/>
</LinearLayout>